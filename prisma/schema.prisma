generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model accounts {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}


model users {
  id            String     @id @default(cuid())
  publicId      String @unique @default(uuid())
  email         String     @unique
  name          String?
  image         String?
  password      String?
  emailVerified DateTime?

  bio            String?
  avatar         String?
  coverImage     String?
  location       String?
  website        String?
  equippedProfileFrameId String?
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  accounts      accounts[]

  posts         post[]
  comments      comment[]
  likes         like[]
  frame_items     user_frame_item[]     // Itens que possui
  resales         cosmetic_resale[] 
  following     follow[]   @relation("follower")
  followers     follow[]   @relation("following")
  created_chats chat[] @relation("chat_creator") 
  buyer_purchases  cosmetic_purchase[] @relation("buyer_purchases")
  seller_purchases cosmetic_purchase[] @relation("seller_purchases")
  chat_members chat_member[]
  coin_transactions coin_transaction[]
  coin_purchases coin_purchase[]
  created_frames cosmetic_frame[]
  cosmetic_reviews     cosmetic_review[]
  cosmetic_review_likes cosmetic_review_like[]



}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model cosmetic_creation_cost {
  id           String   @id @default(cuid())
  rarity       String   @unique
  costCoins    Int
  timeMinutes  Int
}


enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ============================================
// NOVOS MODELOS PARA REDE SOCIAL
// ============================================

model post {
  id         String   @id @default(cuid())
  userId     String
  content    String   @db.Text
  media      String[]
  likes      Int      @default(0)
  commentsCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?
  
  user       users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments   comment[]
  likes_relation like[]
  @@index([userId])
  @@index([createdAt])
}

model comment {
  id         String   @id @default(cuid())
  userId     String
  postId     String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  deletedAt DateTime?
  
  user       users    @relation(fields: [userId], references: [id])
  post       post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model like {
  id         String   @id @default(cuid())
  userId     String
  postId     String
  createdAt  DateTime @default(now())
  
  user       users    @relation(fields: [userId], references: [id])
  post       post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
}

model follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    users    @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   users    @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
}

// ============================================
// MODELOS PARA CHAT (GRUPOS)
// ============================================

model chat {
  id          String        @id @default(cuid())
  name        String
  type       ChatType // "DM" ou "GROUP"
  description String?
  photo       String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  
  creator     users? @relation("chat_creator", fields: [createdBy], references: [id])
  members     chat_member[]
}

model chat_member {
  id         String   @id @default(cuid())
  chatId    String
  userId     String
  role       String   @default("member") // owner, admin, member
  joinedAt   DateTime @default(now())
  
  chat      chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       users    @relation(fields: [userId], references: [id])
  
  @@unique([chatId, userId])
}

enum ChatType {
  DM
  GROUP
}

// ============================================
// MODELOS PARA SISTEMA DE MOEDAS
// ============================================

model coin_package {
  id            String   @id @default(cuid())
  name          String
  coins         Int
  priceReal     Float
  bonusCoins    Int      @default(0)
  isActive      Boolean  @default(true)
  stripePriceId String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  purchases coin_purchase[]
  transactions coin_transaction[]
}

model coin_purchase {
  id              String        @id @default(cuid())
  userId          String
  packageId       String
  amountCoins     Int
  priceReal       Float
  stripeSessionId String?
  stripePaymentIntentId String?
  status          PaymentStatus @default(PENDING)
  paymentIntent   Json?         // Dados do Stripe
  transactions    coin_transaction[] 
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  user            users         @relation(fields: [userId], references: [id])
  package         coin_package  @relation(fields: [packageId], references: [id])
}


model coin_transaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Int      // positivo = ganhou, negativo = gastou
  balance         Int      // saldo após transação
  type            String   // purchase, spend, earn, refund, bonus
  description     String
  stripePaymentId String?
  status          PaymentStatus? // Status do pagamento (se for compra)
  metadata        Json?
  createdAt       DateTime @default(now())
  purchaseId      String?
  packageId       String?
  
  user            users         @relation(fields: [userId], references: [id])
  purchase        coin_purchase? @relation(fields: [purchaseId], references: [id])
  coin_package coin_package? @relation(fields: [packageId], references: [id])

}

// ============================================
// MODELOS PARA COSMÉTICOS (MOLDURAS)
// ============================================

model cosmetic_frame {
  id           String   @id @default(cuid())
  name         String
  description  String?
  imageUrl     String
  thumbnailUrl String
  category     String   @default("PROFILE_PICTURE") // PROFILE_PICTURE, POST, CHAT_BUBBLE
  rarity       String   @default("COMUM") // COMUM, RARO, EPICO, LENDARIO
  stock        Int      @default(1)  // Quantidade disponível para venda
  soldCount    Int      @default(0)  // Quantas já foram vendidas
  priceCoins   Int
  isActive     Boolean  @default(true)
  createdBy    String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  totalSales   Int      @default(0)
  resales cosmetic_resale[]
  items user_frame_item[]
  avgRating      Float            @default(0)
  totalReviews   Int              @default(0)
  total5Stars    Int              @default(0)
  total4Stars    Int              @default(0)
  total3Stars    Int              @default(0)
  total2Stars    Int              @default(0)
  total1Stars    Int              @default(0)
  
  creator      users    @relation(fields: [createdBy], references: [id])
  purchases    cosmetic_purchase[]
  reviews        cosmetic_review[]
}

model cosmetic_purchase {
  id             String   @id @default(cuid())
  frameId        String
  buyerId        String
  sellerId       String
  quantity       Int      @default(1)  // ← NOVO: Quantas unidades comprou
  pricePaid      Int
  platformFee    Int
  sellerEarnings Int
  purchasedAt    DateTime @default(now())
  items user_frame_item[]
  
  frame          cosmetic_frame @relation(fields: [frameId], references: [id], onDelete: Cascade)
  buyer          users          @relation("buyer_purchases", fields: [buyerId], references: [id])
  seller         users          @relation("seller_purchases", fields: [sellerId], references: [id])
  

}

model cosmetic_resale {
  id         String   @id @default(cuid())
  itemId     String   // Referência ao user_frame_item
  frameId    String
  sellerId   String
  price      Int      // Preço de revenda (em moedas)
  status     String   @default("ACTIVE") // ACTIVE, SOLD, CANCELLED
  createdAt  DateTime @default(now())
  expiresAt  DateTime? // Expiracao automática
  
  item       user_frame_item @relation(fields: [itemId], references: [id])
  frame      cosmetic_frame   @relation(fields: [frameId], references: [id])
  seller     users            @relation(fields: [sellerId], references: [id])
  
  @@index([status])
  @@index([frameId])
}

model cosmetic_review {
  id         String   @id @default(cuid())
  frameId    String
  userId     String
  rating     Int      // 1 a 5 estrelas
  title      String?
  comment    String   @db.Text
  images     String[] // URLs de imagens da review (opcional)
  likes      cosmetic_review_like[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  
  frame      cosmetic_frame @relation(fields: [frameId], references: [id], onDelete: Cascade)
  user       users          @relation(fields: [userId], references: [id])
  
  @@unique([frameId, userId]) // 1 review por usuário por moldura
  @@index([frameId])
  @@index([rating])
}

model cosmetic_review_like {
  id         String   @id @default(cuid())
  reviewId   String
  userId     String
  createdAt  DateTime @default(now())
  
  review     cosmetic_review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user       users           @relation(fields: [userId], references: [id])
  
  @@unique([reviewId, userId])
}



model user_frame_item {
  id         String   @id @default(cuid())
  frameId    String
  ownerId    String   // Usuário que possui esta unidade
  purchaseId String   // Compra original
  isListed   Boolean  @default(false)  // Se está à venda
  resalePrice Int?    // Preço de revenda (opcional)
  createdAt  DateTime @default(now())
  soldAt     DateTime?
  soldTo     String?
  resales    cosmetic_resale[]  // ← VÁRIAS revendas (histórico)
  
  frame      cosmetic_frame @relation(fields: [frameId], references: [id])
  owner      users          @relation(fields: [ownerId], references: [id])
  purchase   cosmetic_purchase @relation(fields: [purchaseId], references: [id])
  
  @@unique([frameId, ownerId, id])
}